{
  "name": "mymy-auth",
  "version": "0.1.0",
  "description": "让 AI 全流程跑通手机验证:从 iPhone 拿短信验证码 + 用安卓模拟器里的 B站 App 扫码确认 web 登录,封装为确定性 CLI",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mymy": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts",
    "webhook": "tsx src/sms/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
